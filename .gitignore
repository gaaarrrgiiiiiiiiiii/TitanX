# ============================================================
#  TitanX — .gitignore
# ============================================================

# ---- Java / Maven ----
target/
*.class
*.jar
*.war
*.ear
*.nar

# ---- C++ Build Artifacts ----
backend/build/
backend/build-*/
*.o
*.a
*.so
*.so.*
*.dylib
*.exe
*.out

# ---- CMake ----
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
CTestTestfile.cmake
_deps/

# ---- vcpkg ----
backend/vcpkg_installed/
vcpkg_installed/

# ---- IDE ----
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo

# ---- Logs ----
*.log
logs/

# ---- Docker volumes ----
data/

# ---- Environment / Secrets ----
.env
*.env.local
*.env.production
secrets/

# ---- OS ----
.DS_Store
ehthumbs.db
Desktop.ini
Thumbs.db

# ---- Node / Frontend ----
node_modules/
dist/
.parcel-cache/

# ---- Misc ----
*.zip
*.tar.gz
*.rar
out/
